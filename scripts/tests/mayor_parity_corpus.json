{
  "version": "1.0",
  "description": "Cross-harness parity corpus for run_mayor_loop (Python) / runMayorLoop (TS). Verdict = mayor_events_ordered (Mayor-thread only: beads_update + beads_close, deterministic) + dispatch_calls_sorted (worker calls as sorted multiset, order-independent for parallel). Byte-identical copy in test/mayor-parity-corpus.json.",
  "scenarios": [
    {
      "id": "S1-capacity-sequential",
      "description": "max_workers=1, 3 dep-chained beads. beads_ready reveals each bead only after the previous closes, enforcing sequential execution. Verifies capacity-bound pick ordering and sequential dep-chain unblocking.",
      "config": {
        "max_workers": 1,
        "max_iterations": 25,
        "budget_tokens": 10000000,
        "stuck_threshold_s": 1800,
        "spawning_window_s": 300,
        "max_respawns": 1,
        "verify_cmd": "true",
        "molecule": "test-molecule",
        "repo": "/test/repo",
        "branch": "main"
      },
      "beads": [
        {"id": "gz-s1a", "title": "Implement step A", "priority": 1, "labels": ["tier:implement"], "body": "Step A", "effort": "implement"},
        {"id": "gz-s1b", "title": "Implement step B", "priority": 2, "labels": ["tier:implement"], "body": "Step B", "effort": "implement"},
        {"id": "gz-s1c", "title": "Implement step C", "priority": 3, "labels": ["tier:implement"], "body": "Step C", "effort": "implement"}
      ],
      "dep_chain": [["gz-s1b", "gz-s1a"], ["gz-s1c", "gz-s1b"]],
      "worker_outcomes": {
        "gz-s1a": {"verify_exit": 0, "tokens": 10},
        "gz-s1b": {"verify_exit": 0, "tokens": 10},
        "gz-s1c": {"verify_exit": 0, "tokens": 10}
      },
      "always_return_beads": false,
      "judge_decisions": {},
      "expected_verdict": {
        "mayor_events_ordered": [
          {"type": "beads_update", "bead_id": "gz-s1a", "status": "in_progress"},
          {"type": "beads_close", "bead_id": "gz-s1a"},
          {"type": "beads_update", "bead_id": "gz-s1b", "status": "in_progress"},
          {"type": "beads_close", "bead_id": "gz-s1b"},
          {"type": "beads_update", "bead_id": "gz-s1c", "status": "in_progress"},
          {"type": "beads_close", "bead_id": "gz-s1c"}
        ],
        "dispatch_calls_sorted": [
          {"bead_id": "gz-s1a", "tier": "sonnet"},
          {"bead_id": "gz-s1b", "tier": "sonnet"},
          {"bead_id": "gz-s1c", "tier": "sonnet"}
        ],
        "closed": ["gz-s1a", "gz-s1b", "gz-s1c"],
        "failed": [],
        "stop_reason": "queue-empty"
      }
    },
