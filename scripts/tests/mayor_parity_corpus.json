        {"id": "gz-s3a", "title": "Independent A", "priority": 1, "labels": ["tier:implement"], "body": "A", "effort": "implement"},
        {"id": "gz-s3b", "title": "Independent B", "priority": 2, "labels": ["tier:implement"], "body": "B", "effort": "implement"},
        {"id": "gz-s3c", "title": "Depends on A", "priority": 3, "labels": ["tier:implement"], "body": "C", "effort": "implement"},
        {"id": "gz-s3d", "title": "Depends on B", "priority": 4, "labels": ["tier:implement"], "body": "D", "effort": "implement"}
