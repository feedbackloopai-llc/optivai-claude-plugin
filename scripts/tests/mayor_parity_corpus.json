          {"type": "beads_close", "bead_id": "gz-s3a"},
          {"type": "beads_close", "bead_id": "gz-s3b"},
          {"type": "beads_update", "bead_id": "gz-s3c", "status": "in_progress"},
          {"type": "beads_update", "bead_id": "gz-s3d", "status": "in_progress"},
          {"type": "beads_close", "bead_id": "gz-s3c"},
          {"type": "beads_close", "bead_id": "gz-s3d"}
        ],
        "dispatch_calls_sorted": [
          {"bead_id": "gz-s3a", "tier": "sonnet"},
          {"bead_id": "gz-s3b", "tier": "sonnet"},
          {"bead_id": "gz-s3c", "tier": "sonnet"},
          {"bead_id": "gz-s3d", "tier": "sonnet"}
        ],
        "closed": ["gz-s3a", "gz-s3b", "gz-s3c", "gz-s3d"],
        "failed": [],
        "stop_reason": "queue-empty"
      }
    },
