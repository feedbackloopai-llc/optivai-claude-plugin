        "max_workers": 1,
        "max_iterations": 10,
        "budget_tokens": 10000000,
        "stuck_threshold_s": 1800,
        "spawning_window_s": 300,
        "max_respawns": 1,
        "verify_cmd": "true",
        "molecule": "test-molecule",
        "repo": "/test/repo",
        "branch": "main"
